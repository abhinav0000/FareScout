NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
PUBLIC_WEBHOOK_URL=

# Database and queues
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bus_fare_bot?schema=public
REDIS_URL=redis://localhost:6379

# Collection
# mock or redbus-playwright
FARE_PROVIDER=mock
COLLECTION_INTERVAL_HOURS=6
MAX_ACTIVE_TRIPS_PER_USER=10

# Private-use Playwright provider settings
REDBUS_HEADLESS=false
REDBUS_TIMEOUT_MS=45000
